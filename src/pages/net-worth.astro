          <div id="snapshot-list" class="max-h-40 overflow-y-auto space-y-2"></div>
          <div class="p-4 bg-[#f2efeb] space-y-2">
            <p class="text-[8px] font-bold uppercase tracking-widest opacity-40">Add Past Balance</p>
            <div class="flex gap-2">
              <input type="date" id="past-date" class="bg-white p-2 text-[10px] focus:outline-none flex-1" />
              <input type="number" id="past-balance" placeholder="0.00" class="bg-white p-2 text-[10px] focus:outline-none w-20" />
              <button onclick="savePastSnapshot()" class="bg-[#1a1a1a] text-white px-3 text-[10px] hover:bg-[#B18B53]">Add</button>
            </div>
          </div>
        </div>
        <button onclick="deleteAccount()" class="w-full text-red-500 py-4 text-[10px] font-bold uppercase tracking-widest hover:bg-red-50 transition-colors">Delete Entire Item</button>
        <button type="button" onclick="document.getElementById('edit-modal').close()" class="w-full text-[10px] font-bold uppercase tracking-widest opacity-40">Close</button>
      </div>
    </dialog>

    <dialog id="import-modal" class="bg-white border border-[#1a1a1a]/10 p-12 max-w-sm w-full backdrop:bg-[#1a1a1a]/20 backdrop:backdrop-blur-sm">
        <form id="import-form" class="space-y-6">
          <input type="file" name="file" accept=".csv" required />
          <button type="submit" id="import-btn">Process CSV</button>
        </form>
    </dialog>

</Layout>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script define:vars={{ trendData, categoryData }}>
  // 1. Trend Chart Initialization
  const trendCtx = document.getElementById('trendChart')?.getContext('2d');
  let trendChart;

  const filterTrendData = (interval) => {
    const data = trendData || [];
    if (interval === 'week') {
        return data.filter((_, i) => i % 7 === 0 || i === data.length - 1);
    }
    if (interval === 'month') {
        const months = {};
        data.forEach(d => {
            const m = d.date.substring(0, 7);
            months[m] = d.value;
        });
        return Object.entries(months).map(([date, value]) => ({ date, value }));
    }
    const years = {};
    data.forEach(d => {
        const y = d.date.substring(0, 4);
        years[y] = d.value;
    });
    return Object.entries(years).map(([date, value]) => ({ date, value }));
  };

  if (trendCtx) {
    trendChart = new Chart(trendCtx, {
        type: 'line',
        data: {
        labels: filterTrendData('month').map(d => d.date),
        datasets: [{
            label: 'Net Worth',
            data: filterTrendData('month').map(d => d.value),
            borderColor: '#1a1a1a',
            backgroundColor: 'rgba(26,26,26,0.05)',
            borderWidth: 2,
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#1a1a1a'
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: { display: false },
            x: { 
                grid: { display: false },
                ticks: { font: { size: 9, family: 'Plus Jakarta Sans' }, color: '#1a1a1a' }
            }
        }
        }
    });
  }

  window.updateTrend = (interval) => {
      if (!trendChart) return;
      const data = filterTrendData(interval);
      trendChart.data.labels = data.map(d => d.date);
      trendChart.data.datasets[0].data = data.map(d => d.value);
      trendChart.update();
      
      document.querySelectorAll('.interval-btn').forEach(btn => {
          btn.classList.remove('bg-white', 'shadow-sm', 'opacity-100');
          btn.classList.add('opacity-40');
      });
      const activeBtn = Array.from(document.querySelectorAll('.interval-btn')).find(b => b.textContent.toLowerCase() === interval);
      if (activeBtn) {
        activeBtn.classList.add('bg-white', 'shadow-sm', 'opacity-100');
        activeBtn.classList.remove('opacity-40');
      }
  };

  // 2. Allocation Chart Initialization
  const allocCtx = document.getElementById('allocationChart')?.getContext('2d');
  if (allocCtx) {
    new Chart(allocCtx, {
        type: 'doughnut',
        data: {
        labels: Object.keys(categoryData),
        datasets: [{
            data: Object.values(categoryData).map(d => d.value),
            backgroundColor: ['#1a1a1a', '#B18B53', '#7ea493', '#f2efeb', '#888'],
            borderWidth: 0,
            hoverOffset: 10
        }]
        },
        options: {
        cutout: '80%',
        plugins: { legend: { display: false } }
        }
    });
  }

  // Global variables and state
  let currentItem = null;
  const categories = {
    asset: ['Cash', 'Investments', 'Property', 'Business Equity'],
    liability: ['Credit Cards', 'Auto Loan', 'Mortgage', 'Student Loan', 'Other']
  };

  window.openEditModal = (item) => {
    currentItem = item;
    const modal = document.getElementById('edit-modal');
    document.getElementById('edit-id').value = item.id;
    document.getElementById('edit-name').value = item.name;
    
    const editCategorySelect = document.getElementById('edit-category');
    editCategorySelect.innerHTML = '';
    categories[item.type].forEach(cat => {
      const opt = document.createElement('option');
      opt.value = cat; opt.textContent = cat;
      if (cat === item.category) opt.selected = true;
      editCategorySelect.appendChild(opt);
    });

    const list = document.getElementById('snapshot-list');
    list.innerHTML = '';
    (item.allSnapshots || []).forEach(snap => {
      const div = document.createElement('div');
      div.className = 'flex justify-between items-center p-3 bg-white border border-[#1a1a1a]/5 text-[10px]';
      div.innerHTML = `<span>${snap.snapshot_date}</span><input type="number" value="${snap.balance}" onchange="saveSnapshot('${item.id}', this.value, '${snap.snapshot_date}')" class="w-16 font-bold focus:outline-none bg-transparent text-right" />`;
      list.appendChild(div);
    });
    modal?.showModal();
  };

  window.saveSnapshot = async (id, val, date = null) => {
    const body = new URLSearchParams({ accountId: id, balance: val });
    if (date) body.append('date', date);
    await fetch('/api/snapshots', { method: 'POST', body });
  };

  window.savePastSnapshot = async () => {
    const date = document.getElementById('past-date').value;
    const balance = document.getElementById('past-balance').value;
    if (!date || !balance) return alert('Date and balance required');
    await window.saveSnapshot(currentItem.id, balance, date);
    location.reload();
  };

  window.deleteAccount = async () => {
    if (!confirm('Delete entire item?')) return;
    const res = await fetch(`/api/accounts?id=${currentItem.id}`, { method: 'DELETE' });
    if (res.ok) location.reload();
  };

  // Helper for dynamic category updates
  const typeSelect = document.getElementById('type-select');
  const categorySelect = document.getElementById('category-select');

  function updateCategories() {
    const type = typeSelect?.value;
    if (!categorySelect || !type) return;
    categorySelect.innerHTML = '';
    categories[type].forEach(cat => {
      const opt = document.createElement('option');
      opt.value = cat; opt.textContent = cat;
      categorySelect.appendChild(opt);
    });
  }
  typeSelect?.addEventListener('change', updateCategories);
  updateCategories();

  document.getElementById('edit-item-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const res = await fetch('/api/accounts/update', { method: 'POST', body: formData });
    if (res.ok) location.reload();
  });
</script>

<style>
  dialog::backdrop { background: rgba(26, 26, 26, 0.2); backdrop-filter: blur(4px); }
  input[type="number"]::-webkit-inner-spin-button { display: none; }
</style>
