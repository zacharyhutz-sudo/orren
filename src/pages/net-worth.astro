        <button onclick="document.getElementById('import-modal').showModal()" class="w-full md:w-auto text-[10px] font-bold uppercase tracking-widest border border-[#1a1a1a]/10 px-8 py-4 md:py-2 hover:bg-[#B18B53] hover:text-white transition-colors">
            Import CSV
        </button>
        <button onclick="document.getElementById('add-modal').showModal()" class="w-full md:w-auto text-[10px] font-bold uppercase tracking-widest border border-[#1a1a1a]/10 px-8 py-4 md:py-2 bg-[#1a1a1a] text-white hover:bg-black transition-colors">
            + Add Item
