      <h3 class="text-6xl font-bold tracking-tighter">${netWorth.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</h3>
    </div>

    <!-- Trend Chart -->
    <section class="bg-white p-8 border border-[#1a1a1a]/5 space-y-8">
      <div class="flex justify-between items-center">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Performance</h4>
        <div class="flex bg-[#f2efeb] p-1 rounded">
          <button onclick="updateTrend('week')" class="interval-btn px-3 py-1 text-[8px] font-bold uppercase tracking-widest opacity-40 hover:opacity-100 transition-opacity">Week</button>
          <button onclick="updateTrend('month')" class="interval-btn px-3 py-1 text-[8px] font-bold uppercase tracking-widest bg-white shadow-sm opacity-100">Month</button>
          <button onclick="updateTrend('year')" class="interval-btn px-3 py-1 text-[8px] font-bold uppercase tracking-widest opacity-40 hover:opacity-100 transition-opacity">Year</button>
        </div>
      </div>
      <div class="h-64 w-full">
        <canvas id="trendChart"></canvas>
      </div>
    </section>

    <!-- Allocation Chart -->
    <section class="bg-white p-12 border border-[#1a1a1a]/5 space-y-12">
        <header class="text-center space-y-2">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.3em] opacity-40">Asset Allocation</h4>
            <p class="font-['Cormorant_Garamond'] italic text-2xl">Portfolio Composition</p>
        </header>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
