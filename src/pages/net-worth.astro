---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;

if (!accessToken || !refreshToken) {
  return Astro.redirect("/signin");
}

const { data: authData, error: authError } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});

if (authError || !authData.user) {
  return Astro.redirect("/signin");
}

// Fetch accounts and their snapshots
const { data: accounts, error: accountsError } = await supabase
  .from('accounts')
  .select(`
    *,
    account_snapshots (
      id,
      balance,
      snapshot_date
    )
  `)
  .eq('user_id', authData.user.id);

if (accountsError) console.error(accountsError);

// 1. Generate Milestones (Unique dates with data)
const allSnapshots = (accounts || []).flatMap(acc => acc.account_snapshots.map((s: any) => ({
    ...s,
    accountId: acc.id,
    type: acc.type,
    category: acc.category,
    name: acc.name
})));

const milestoneDates = [...new Set(allSnapshots.map(s => s.snapshot_date))].sort();

// 2. Build full state for every milestone
const milestoneData = milestoneDates.map((date, index) => {
    let totalAssets = 0;
    let totalLiabilities = 0;
    
    const accountStates = (accounts || []).map(acc => {
        const snap = acc.account_snapshots
            .filter((s: any) => s.snapshot_date <= date)
            .sort((a: any, b: any) => new Date(b.snapshot_date).getTime() - new Date(a.snapshot_date).getTime())[0];
        
        const balance = snap ? Number(snap.balance) : 0;
        if (acc.type === 'asset') totalAssets += balance;
        else totalLiabilities += balance;

        return {
            id: acc.id,
            name: acc.name,
            type: acc.type,
            category: acc.category,
            balance: balance,
            lastUpdate: snap ? snap.snapshot_date : 'Never'
        };
    });

    const netWorth = totalAssets - totalLiabilities;
    return {
        date,
        netWorth,
        totalAssets,
        totalLiabilities,
        accounts: accountStates
    };
});

const latestMilestone = milestoneData[milestoneData.length - 1] || { 
    date: new Date().toISOString().split('T')[0], 
    netWorth: 0, totalAssets: 0, totalLiabilities: 0, accounts: [] 
};

// Data for Sync Mode
const syncAccounts = (accounts || []).map(acc => {
    const latestSnap = acc.account_snapshots.sort((a: any, b: any) => new Date(b.snapshot_date).getTime() - new Date(a.snapshot_date).getTime())[0];
    return {
        ...acc,
        latestBalance: latestSnap ? Number(latestSnap.balance) : 0,
        latestDate: latestSnap ? latestSnap.snapshot_date : null
    };
}).sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title="Net Worth">
  <script is:inline define:vars={{ milestoneData, syncAccounts }}>
    window.ORREN_MILESTONES = milestoneData;
    window.ORREN_SYNC_ACCOUNTS = syncAccounts;
  </script>

  <div class="space-y-0 pb-32">
    <nav class="sticky top-0 z-50 bg-[#f2efeb]/80 backdrop-blur-md border-b border-[#1a1a1a]/5 overflow-x-auto no-scrollbar">
        <div class="flex px-6 py-4 gap-8 min-w-max mx-auto max-w-2xl">
            {milestoneData.map((m, i) => {
                const dateObj = new Date(m.date + 'T12:00:00');
                const month = dateObj.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
                const day = dateObj.toLocaleDateString('en-US', { day: '2-digit' });
                const isLast = i === milestoneData.length - 1;
                return (
                    <button data-date={m.date} class={`milestone-btn group flex flex-col items-center gap-1 transition-all ${isLast ? 'active' : 'opacity-30 hover:opacity-60'}`}>
                        <span class="text-[8px] font-bold tracking-[0.2em]">{month}</span>
                        <span class="text-xl font-bold tracking-tighter leading-none group-[.active]:text-[#B18B53]">{day}</span>
                        <div class="w-1 h-1 rounded-full bg-[#B18B53] scale-0 group-[.active]:scale-100 transition-transform"></div>
                    </button>
                )
            })}
        </div>
    </nav>

    <div class="px-6 py-12 max-w-2xl mx-auto space-y-12">
        <header class="space-y-6 md:flex md:justify-between md:items-end md:space-y-0">
        <div>
            <h2 class="text-5xl font-['Cormorant_Garamond'] italic tracking-tighter">Net Worth</h2>
            <p id="display-date" class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Recorded: {latestMilestone.date}</p>
        </div>
        <div class="flex flex-col gap-3 md:flex-row md:gap-2 w-full md:w-auto">
            <button id="btn-sync-mode" class="w-full md:w-auto text-[10px] font-bold uppercase tracking-widest border border-[#B18B53]/30 bg-[#B18B53]/10 text-[#B18B53] px-8 py-4 md:py-2 hover:bg-[#B18B53] hover:text-white transition-all">
                Update Balances
            </button>
            <button id="btn-open-add" class="w-full md:w-auto text-[10px] font-bold uppercase tracking-widest border border-[#1a1a1a]/10 px-8 py-4 md:py-2 bg-[#1a1a1a] text-white hover:bg-black transition-colors">+ Add Account</button>
        </div>
        </header>

        <div class="bg-[#1a1a1a] text-white p-12 text-center space-y-4 relative overflow-hidden group">
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] opacity-40">Net Worth</span>
            <div class="space-y-1">
                <h3 id="display-networth" class="text-6xl font-bold tracking-tighter transition-all duration-500">${latestMilestone.netWorth.toLocaleString(undefined, { minimumFractionDigits: 2 })}</h3>
                <p id="display-delta" class="text-[10px] font-bold tracking-widest opacity-0 transition-all"></p>
            </div>
            <div id="worth-pulse" class="absolute inset-0 bg-[#7ea493]/10 opacity-0 pointer-events-none transition-opacity duration-300"></div>
        </div>

        <section class="bg-white p-8 border border-[#1a1a1a]/5 space-y-8">
            <div class="flex justify-between items-center"><h4 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Growth Trend</h4></div>
            <div class="h-64 w-full"><canvas id="trendChart"></canvas></div>
        </section>

        <section class="bg-white p-12 border border-[#1a1a1a]/5 space-y-12">
            <header class="text-center space-y-2"><h4 class="text-[10px] font-bold uppercase tracking-[0.3em] opacity-40">Allocation</h4><p class="font-['Cormorant_Garamond'] italic text-2xl">Portfolio Composition</p></header>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                <div class="relative aspect-square max-w-[200px] mx-auto w-full"><canvas id="allocationChart"></canvas></div>
                <div id="allocation-legend" class="space-y-6"></div>
            </div>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <section class="space-y-6"><h4 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Assets</h4><div id="assets-list" class="space-y-3"></div></section>
            <section class="space-y-6"><h4 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Liabilities</h4><div id="liabilities-list" class="space-y-3"></div></section>
        </div>
    </div>
  </div>

  <!-- Sync Mode Modal -->
  <dialog id="sync-modal" class="p-0 md:max-w-lg">
      <div class="flex flex-col h-full md:h-[80vh]">
          <header class="p-8 border-b border-[#1a1a1a]/5 bg-[#f2efeb]/50">
              <div class="flex justify-between items-start mb-6">
                <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Update Balances</h3>
                <button class="btn-close-modal opacity-40 hover:opacity-100"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg></button>
              </div>
              <div class="space-y-2">
                <label class="text-[8px] font-bold uppercase tracking-widest opacity-40">Milestone Date</label>
                <input type="date" id="sync-date" class="w-full bg-white p-3 text-base font-bold focus:outline-none border border-[#1a1a1a]/5" />
              </div>
          </header>
          
          <div class="flex-1 overflow-y-auto p-8 space-y-4 no-scrollbar">
              <div id="sync-items-list" class="space-y-2">
                  <!-- Items injected here -->
              </div>
          </div>

          <footer class="p-8 bg-[#f2efeb]/50 border-t border-[#1a1a1a]/5 grid grid-cols-2 gap-4">
              <button class="btn-close-modal text-[10px] font-bold uppercase tracking-widest opacity-40 py-4">Cancel</button>
              <button id="btn-save-sync" class="bg-[#1a1a1a] text-white py-4 text-[10px] font-bold uppercase tracking-widest hover:bg-[#B18B53] transition-colors">Finish Sync</button>
          </footer>
      </div>
  </dialog>

  <!-- Existing Modals -->
  <dialog id="add-modal" class="p-6 md:p-12 md:max-w-sm">
      <form action="/api/accounts" method="POST" class="space-y-8">
        <header class="space-y-2 text-center"><h3 id="add-modal-title" class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Add Asset</h3></header>
        <div class="space-y-4">
          <input type="text" name="name" required class="w-full bg-[#f2efeb] p-4 text-base focus:outline-none" placeholder="Name" />
          <select name="type" id="type-select" class="w-full bg-[#f2efeb] p-4 text-base focus:outline-none"><option value="asset">Asset</option><option value="liability">Liability</option></select>
          <select name="category" id="category-select" class="w-full bg-[#f2efeb] p-4 text-base focus:outline-none"></select>
          <input type="number" step="0.01" name="balance" required class="w-full bg-[#f2efeb] p-4 text-base focus:outline-none" placeholder="Initial Value" />
        </div>
        <div class="flex flex-col gap-4">
          <button type="submit" class="bg-[#1a1a1a] text-white py-4 text-[10px] font-bold uppercase tracking-widest hover:bg-[#B18B53] transition-colors">Add Item</button>
          <button type="button" class="btn-close-modal text-[10px] font-bold uppercase tracking-widest opacity-40">Cancel</button>
        </div>
      </form>
    </dialog>

    <dialog id="edit-modal" class="p-6 md:p-12 md:max-w-sm">
      <div class="space-y-8">
        <header class="space-y-2 text-center"><h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Edit Item</h3></header>
        <form id="edit-item-form" class="space-y-4">
          <input type="hidden" name="id" id="edit-id" />
          <input type="text" name="name" id="edit-name" required class="w-full bg-[#f2efeb] p-4 text-base focus:outline-none" />
          <select name="category" id="edit-category" class="w-full bg-[#f2efeb] p-4 text-base focus:outline-none"></select>
          <button type="submit" class="w-full bg-[#1a1a1a] text-white py-4 text-[10px] font-bold uppercase tracking-widest hover:bg-[#B18B53] transition-colors">Save Details</button>
        </form>
        <div class="pt-8 border-t border-[#1a1a1a]/5 space-y-4">
          <header class="text-center"><h4 class="text-[10px] font-bold uppercase tracking-widest opacity-40">Edit History</h4></header>
          <div id="snapshot-list" class="max-h-40 overflow-y-auto space-y-2"></div>
          <div class="p-4 bg-[#f2efeb] space-y-2">
            <p class="text-[8px] font-bold uppercase tracking-widest opacity-40">Add Past Balance</p>
            <div class="flex gap-2">
              <input type="date" id="past-date" class="bg-white p-2 text-base focus:outline-none flex-1" />
              <input type="number" id="past-balance" placeholder="0.00" class="bg-white p-2 text-base focus:outline-none w-20" />
              <button id="btn-add-past" class="bg-[#1a1a1a] text-white px-3 text-[10px] hover:bg-[#B18B53]">Add</button>
            </div>
          </div>
        </div>
        <button id="btn-delete-item" class="w-full text-red-500 py-4 text-[10px] font-bold uppercase tracking-widest hover:bg-red-50 transition-colors">Delete Entire Account</button>
        <button type="button" class="btn-close-modal w-full text-[10px] font-bold uppercase tracking-widest opacity-40">Close</button>
      </div>
    </dialog>

    <!-- Mobile Primary Action -->
    <button id="fab-update-balances" class="md:hidden fixed bottom-24 right-6 w-14 h-14 bg-[#B18B53] text-white rounded-full shadow-2xl flex items-center justify-center z-[60] active:scale-90 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
    </button>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const milestones = window.ORREN_MILESTONES || [];
    let currentMilestone = milestones[milestones.length - 1];
    let trendChart, allocChart;
    window.ORREN_CURRENT_ITEM = null;

    const categories = {
        asset: ['Cash', 'Investments', 'Property', 'Business Equity'],
        liability: ['Credit Cards', 'Auto Loan', 'Mortgage', 'Student Loan', 'Other']
    };

    function checkStale(date) {
        if (!date) return true;
        const last = new Date(date);
        const now = new Date();
        const diff = (now - last) / (1000 * 60 * 60 * 24);
        return diff > 30;
    }

    async function saveSnapshot(id, val, date = null) {
        const body = new URLSearchParams({ accountId: id, balance: val });
        if (date) body.append('date', date);
        
        // Phase 3: Visual Pulse
        const pulse = document.getElementById('worth-pulse');
        pulse.style.opacity = '1';
        setTimeout(() => pulse.style.opacity = '0', 300);

        await fetch('/api/snapshots', { method: 'POST', body });
    }

    function renderMilestone(m) {
        const idx = milestones.findIndex(ms => ms.date === m.date);
        const prev = idx > 0 ? milestones[idx - 1] : null;
        document.getElementById('display-networth').textContent = `$${m.netWorth.toLocaleString(undefined, { minimumFractionDigits: 2 })}`;
        document.getElementById('display-date').textContent = `Recorded: ${m.date}`;
        const deltaEl = document.getElementById('display-delta');
        if (prev) {
            const diff = m.netWorth - prev.netWorth;
            deltaEl.textContent = `${diff >= 0 ? '+' : ''}$${diff.toLocaleString()} since last milestone`;
            deltaEl.className = `text-[10px] font-bold tracking-widest transition-all ${diff >= 0 ? 'text-[#7ea493]' : 'text-[#B18B53]'}`;
        } else deltaEl.className = 'opacity-0';

        const renderList = (id, items, type) => {
            const container = document.getElementById(id); container.innerHTML = '';
            items.filter(i => i.type === type).sort((a,b) => b.balance - a.balance).forEach(item => {
                const perc = type === 'asset' ? Math.round((item.balance / m.totalAssets) * 100) : 0;
                const isStale = checkStale(item.lastUpdate);
                
                const div = document.createElement('div');
                div.className = `group bg-white p-6 border-l-2 relative ${type === 'asset' ? 'border-[#7ea493]' : 'border-[#B18B53]/20'}`;
                div.innerHTML = `
                    <div class="flex justify-between items-start mb-4">
                        <div class="space-y-1">
                            <div class="flex items-center gap-2">
                                <span class="font-['Cormorant_Garamond'] italic text-lg leading-none">${item.name}</span>
                                ${perc > 0 ? `<span class="text-[8px] font-bold text-[#7ea493] bg-[#7ea493]/10 px-1.5 py-0.5 rounded">${perc}%</span>` : ''}
                                ${isStale ? `<span class="text-[7px] font-bold text-[#B18B53] border border-[#B18B53]/20 px-1 py-0.5 rounded uppercase tracking-widest">Stale</span>` : ''}
                            </div>
                            <span class="text-[8px] font-bold uppercase tracking-widest opacity-30">${item.category || (type === 'asset' ? 'Cash' : 'Other')} • Updated: ${item.lastUpdate}</span>
                        </div>
                        <button class="btn-edit-item opacity-40 hover:opacity-100 p-1" data-id="${item.id}"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-[10px] font-bold opacity-30">$</span>
                        <input type="number" value="${item.balance}" data-id="${item.id}" class="input-balance w-full font-bold tracking-tighter text-xl focus:outline-none focus:text-[#B18B53] transition-colors bg-transparent" />
                    </div>`;
                container.appendChild(div);
            });
        };
        renderList('assets-list', m.accounts, 'asset'); renderList('liabilities-list', m.accounts, 'liability');

        if (m.accounts.length === 0) {
            const assetsList = document.getElementById('assets-list');
            const liabilitiesList = document.getElementById('liabilities-list');
            const emptyState = `
                <div class="py-8 border border-dashed border-[#1a1a1a]/10 text-center space-y-3">
                    <p class="text-[9px] font-bold uppercase tracking-widest opacity-40">No items yet</p>
                    <button onclick="document.getElementById('add-modal').showModal()" class="text-[8px] font-bold uppercase tracking-widest border border-[#1a1a1a]/10 px-3 py-1.5 hover:bg-[#f2efeb]">Add My First Account</button>
                </div>
            `;
            assetsList.innerHTML = emptyState;
            liabilitiesList.innerHTML = emptyState;
        }

        const catMap = m.accounts.filter(a => a.type === 'asset').reduce((acc, item) => {
            if (!acc[item.category]) acc[item.category] = { value: 0, items: [] };
            acc[item.category].value += item.balance; acc[item.category].items.push(item);
            return acc;
        }, {});
        if (allocChart) { allocChart.data.labels = Object.keys(catMap); allocChart.data.datasets[0].data = Object.values(catMap).map(c => c.value); allocChart.update(); }
        const legend = document.getElementById('allocation-legend'); legend.innerHTML = '';
        Object.entries(catMap).forEach(([cat, data]) => {
            const div = document.createElement('div'); div.className = 'space-y-2';
            const catName = cat === 'null' || !cat ? 'Uncategorized' : cat;
            const perc = Math.round((data.value / m.totalAssets) * 100);
            div.innerHTML = `<div class=\"flex justify-between items-end border-b border-[#1a1a1a]/5 pb-1\"><span class=\"text-[10px] font-bold uppercase tracking-widest\">${catName}</span><div class=\"text-right\"><span class=\"text-[10px] font-bold block\">$${data.value.toLocaleString()}</span><span class=\"text-[8px] font-bold opacity-40 uppercase\">${perc}%</span></div></div><div class=\"space-y-1\">${data.items.map(i => `<div class=\"flex justify-between text-[9px] opacity-60\"><span>${i.name}</span><span>$${i.balance.toLocaleString()}</span></div>`).join('')}</div>`;
            legend.appendChild(div);
        });
        attachListeners();
    }

    function initCharts() {
        const trendCtx = document.getElementById('trendChart')?.getContext('2d');
        if (trendCtx) {
            trendChart = new Chart(trendCtx, {
                type: 'line',
                data: { labels: milestones.map(ms => ms.date), datasets: [{ data: milestones.map(ms => ms.netWorth), borderColor: '#1a1a1a', backgroundColor: 'rgba(26,26,26,0.05)', fill: true, tension: 0.4, pointRadius: 4, pointBackgroundColor: '#1a1a1a' }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { display: false }, x: { ticks: { font: { size: 9 }, color: '#1a1a1a' }, grid: { display: false } } } }
            });
        }
        const allocCtx = document.getElementById('allocationChart')?.getContext('2d');
        if (allocCtx) { allocChart = new Chart(allocCtx, { type: 'doughnut', data: { labels: [], datasets: [{ data: [], backgroundColor: ['#1a1a1a', '#B18B53', '#7ea493', '#f2efeb', '#888'], borderWidth: 0 }] }, options: { cutout: '80%', plugins: { legend: { display: false } } } }); }
    }

    function attachListeners() {
        document.querySelectorAll('.milestone-btn').forEach(btn => { btn.onclick = () => { const date = btn.dataset.date; currentMilestone = milestones.find(ms => ms.date === date); document.querySelectorAll('.milestone-btn').forEach(b => { b.classList.remove('active', 'opacity-100'); b.classList.add('opacity-30'); }); btn.classList.add('active', 'opacity-100'); btn.classList.remove('opacity-30'); renderMilestone(currentMilestone); }; });
        document.querySelectorAll('.btn-edit-item').forEach(btn => { btn.onclick = () => { const item = currentMilestone.accounts.find(a => a.id === btn.dataset.id); window.ORREN_CURRENT_ITEM = item; openEditModal(item); }; });
        document.querySelectorAll('.input-balance').forEach(input => { input.onchange = () => saveSnapshot(input.dataset.id, input.value, currentMilestone.date); });
    }

    // Phase 1: Sync Mode Logic
    document.getElementById('btn-sync-mode').onclick = () => {
        const modal = document.getElementById('sync-modal');
        const list = document.getElementById('sync-items-list');
        const dateInput = document.getElementById('sync-date');
        
        dateInput.value = new Date().toISOString().split('T')[0];
        list.innerHTML = '';
        
        window.ORREN_SYNC_ACCOUNTS.forEach(acc => {
            const div = document.createElement('div');
            div.className = 'flex justify-between items-center p-4 bg-[#f2efeb]/30 border border-[#1a1a1a]/5';
            div.innerHTML = `
                <div class="space-y-0.5">
                    <p class="text-[10px] font-bold uppercase tracking-tight">${acc.name}</p>
                    <p class="text-[8px] opacity-40 uppercase tracking-widest">${acc.category}</p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-[10px] opacity-20">$</span>
                    <input type="number" step="0.01" value="${acc.latestBalance}" data-id="${acc.id}" class="sync-input bg-white border border-[#1a1a1a]/5 p-2 text-right text-base font-bold w-28 focus:outline-none focus:border-[#B18B53] transition-colors" />
                </div>
            `;
            list.appendChild(div);
        });
        
        modal.showModal();
    };

    document.getElementById('btn-save-sync').onclick = async () => {
        const date = document.getElementById('sync-date').value;
        const inputs = document.querySelectorAll('.sync-input');
        
        for (const input of inputs) {
            await saveSnapshot(input.dataset.id, input.value, date);
        }
        
        location.reload();
    };

    function openEditModal(item) {
        document.getElementById('edit-id').value = item.id; document.getElementById('edit-name').value = item.name;
        const editCat = document.getElementById('edit-category'); editCat.innerHTML = '';
        categories[item.type].forEach(cat => { const opt = document.createElement('option'); opt.value = cat; opt.textContent = cat; if (cat === item.category) opt.selected = true; editCat.appendChild(opt); });
        const snapshots = (milestones || []).flatMap(m => m.accounts.filter(a => a.id === item.id).map(a => ({ snapshot_date: m.date, balance: a.balance })));
        const list = document.getElementById('snapshot-list'); list.innerHTML = '';
        snapshots.sort((a,b) => new Date(b.snapshot_date).getTime() - new Date(a.snapshot_date).getTime()).forEach(snap => {
            const div = document.createElement('div'); div.className = 'flex justify-between items-center p-3 bg-white border border-[#1a1a1a]/5 text-[10px]';
            div.innerHTML = `<span>${snap.snapshot_date}</span><input type=\"number\" value=\"${snap.balance}\" class=\"snap-input w-16 font-bold text-right\" data-date=\"${snap.snapshot_date}\">`;
            list.appendChild(div);
        });
        list.querySelectorAll('.snap-input').forEach(input => { input.onchange = () => saveSnapshot(item.id, input.value, input.dataset.date); });
        document.getElementById('edit-modal').showModal();
    }

    document.getElementById('edit-item-form').onsubmit = async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = {
            id: formData.get('id'),
            name: formData.get('name'),
            category: formData.get('category')
        };
        const res = await fetch('/api/accounts', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        if (res.ok) {
            window.orren.toast('Account updated');
            setTimeout(() => location.reload(), 1000);
        }
        else window.orren.toast('Error updating item', 'error');
    };

    document.getElementById('btn-open-add')?.addEventListener('click', () => document.getElementById('add-modal').showModal());
    document.getElementById('fab-update-balances')?.addEventListener('click', () => document.getElementById('btn-sync-mode').click());
    document.querySelectorAll('.btn-close-modal').forEach(btn => btn.onclick = () => btn.closest('dialog').close());
    document.getElementById('btn-add-past')?.addEventListener('click', async () => { 
        const date = document.getElementById('past-date').value; 
        const bal = document.getElementById('past-balance').value; 
        if (!date || !bal || !window.ORREN_CURRENT_ITEM) return window.orren.toast('Data missing', 'error'); 
        await saveSnapshot(window.ORREN_CURRENT_ITEM.id, bal, date); 
        window.orren.toast('Historical balance added');
        location.reload(); 
    });
    document.getElementById('btn-delete-item')?.addEventListener('click', async () => { 
        if (!window.ORREN_CURRENT_ITEM || !window.orren.confirm('Delete this account and all history?')) return; 
        const res = await fetch(`/api/accounts?id=${window.ORREN_CURRENT_ITEM.id}`, { method: 'DELETE' }); 
        if (res.ok) {
            window.orren.toast('Account removed');
            location.reload(); 
        }
    });

    const typeSelect = document.getElementById('type-select'); const catSelect = document.getElementById('category-select');
    const titleEl = document.getElementById('add-modal-title');
    const updateCats = () => { 
        catSelect.innerHTML = ''; 
        categories[typeSelect.value].forEach(cat => { 
            const opt = document.createElement('option'); 
            opt.value = cat; 
            opt.textContent = cat; 
            catSelect.appendChild(opt); 
        }); 
        titleEl.textContent = typeSelect.value === 'asset' ? 'Add Asset' : 'Add Debt';
    };
    typeSelect?.addEventListener('change', updateCats); updateCats();

    initCharts(); renderMilestone(currentMilestone);
    const nav = document.querySelector('nav'); nav.scrollLeft = nav.scrollWidth;
  });
</script>

<style>
  input[type="number"]::-webkit-inner-spin-button { display: none; }
  .milestone-btn.active { opacity: 1 !important; }
</style>
