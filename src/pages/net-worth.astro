        </div>
      </section>

      <section class="space-y-6">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Liabilities</h4>
        <div class="space-y-3">
          {liabilities.map(item => (
            <div class="group bg-white p-6 border-l-2 border-[#B18B53]/20 relative">
              <div class="flex justify-between items-start mb-4">
                <div class="space-y-1">
                  <span class="font-['Cormorant_Garamond'] italic text-lg block leading-none">{item.name}</span>
                  <span class="text-[8px] font-bold uppercase tracking-widest opacity-30 block">{item.category} • Updated: {item.lastUpdate}</span>
                </div>
                <button onclick={`openEditModal(${JSON.stringify(item)})`} class="opacity-40 hover:opacity-100 transition-opacity p-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-[10px] font-bold opacity-30">$</span>
                <input type="number" value={item.balance} onchange={`saveSnapshot('${item.id}', this.value)`} class="w-full font-bold tracking-tighter text-xl focus:outline-none focus:text-[#B18B53] transition-colors bg-transparent" />
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>

  <!-- Modals -->
  <dialog id="add-modal" class="bg-white border border-[#1a1a1a]/10 p-12 max-w-sm w-full backdrop:bg-[#1a1a1a]/20 backdrop:backdrop-blur-sm">
      <form action="/api/accounts" method="POST" class="space-y-8">
        <header class="space-y-2 text-center">
          <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Add Item</h3>
        </header>
        <div class="space-y-4">
          <input type="text" name="name" required class="w-full bg-[#f2efeb] p-4 text-sm focus:outline-none" placeholder="Name" />
          <select name="type" id="type-select" class="w-full bg-[#f2efeb] p-4 text-sm focus:outline-none">
            <option value="asset">Asset</option>
            <option value="liability">Liability</option>
          </select>
          <select name="category" id="category-select" class="w-full bg-[#f2efeb] p-4 text-sm focus:outline-none"></select>
          <input type="number" step="0.01" name="balance" required class="w-full bg-[#f2efeb] p-4 text-sm focus:outline-none" placeholder="Initial Value" />
        </div>
        <div class="flex flex-col gap-4">
          <button type="submit" class="bg-[#1a1a1a] text-white py-4 text-[10px] font-bold uppercase tracking-widest hover:bg-[#B18B53] transition-colors">Add Item</button>
          <button type="button" onclick="document.getElementById('add-modal').close()" class="text-[10px] font-bold uppercase tracking-widest opacity-40">Cancel</button>
        </div>
      </form>
    </dialog>

    <dialog id="edit-modal" class="bg-white border border-[#1a1a1a]/10 p-12 max-w-sm w-full backdrop:bg-[#1a1a1a]/20 backdrop:backdrop-blur-sm">
      <div class="space-y-8">
        <header class="space-y-2 text-center">
          <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Edit Item</h3>
        </header>
        <form id="edit-item-form" class="space-y-4">
          <input type="hidden" name="id" id="edit-id" />
          <input type="text" name="name" id="edit-name" required class="w-full bg-[#f2efeb] p-4 text-sm focus:outline-none" />
          <select name="category" id="edit-category" class="w-full bg-[#f2efeb] p-4 text-sm focus:outline-none"></select>
          <button type="submit" class="w-full bg-[#1a1a1a] text-white py-4 text-[10px] font-bold uppercase tracking-widest hover:bg-[#B18B53] transition-colors">Save Details</button>
        </form>
        <div class="pt-8 border-t border-[#1a1a1a]/5 space-y-4">
