---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;

if (!accessToken || !refreshToken) {
  return Astro.redirect("/signin");
}

const { data: authData, error: authError } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});

if (authError || !authData.user) {
  return Astro.redirect("/signin");
}

// Fetch accounts and their snapshots
const { data: accounts, error: accountsError } = await supabase
  .from('accounts')
  .select(`
    *,
    account_snapshots (
      id,
      balance,
      snapshot_date
    )
  `)
  .eq('user_id', authData.user.id);

if (accountsError) console.error(accountsError);

// Process data for the UI
const processedAccounts = (accounts || []).map(acc => {
  const snapshots = acc.account_snapshots?.sort((a: any, b: any) => 
    new Date(b.snapshot_date).getTime() - new Date(a.snapshot_date).getTime()
  ) || [];
  const latestSnapshot = snapshots[0];
  return {
    ...acc,
    balance: latestSnapshot?.balance || 0,
    lastUpdate: latestSnapshot?.snapshot_date || 'Never',
    allSnapshots: snapshots
  };
});

const assets = processedAccounts.filter(a => a.type === 'asset').sort((a, b) => b.balance - a.balance);
const liabilities = processedAccounts.filter(a => a.type === 'liability').sort((a, b) => b.balance - a.balance);

const totalAssets = assets.reduce((sum, a) => sum + Number(a.balance), 0);
const totalLiabilities = liabilities.reduce((sum, a) => sum + Number(a.balance), 0);
const netWorth = totalAssets - totalLiabilities;

// Prepare data for the Allocation Chart (Category based)
const categoryData = assets.reduce((acc: any, item) => {
    const cat = item.category || 'Other';
    if (!acc[cat]) acc[cat] = { value: 0, items: [] };
    acc[cat].value += Number(item.balance);
    acc[cat].items.push({ name: item.name, balance: item.balance });
    return acc;
}, {});

// Prepare Trend Data (Historical)
// We'll collect all unique dates and sum up the latest balance of every account for that date
const allDates = [...new Set((accounts || []).flatMap(acc => acc.account_snapshots.map((s: any) => s.snapshot_date)))].sort();
const trendData = allDates.map(date => {
    let total = 0;
    (accounts || []).forEach(acc => {
        const snapForDate = acc.account_snapshots.find((s: any) => s.snapshot_date === date);
        if (snapForDate) {
            total += (acc.type === 'asset' ? 1 : -1) * snapForDate.balance;
        } else {
            // Carry forward previous balance if not set for this date
            const prevSnap = acc.account_snapshots
                .filter((s: any) => s.snapshot_date < date)
                .sort((a: any, b: any) => new Date(b.snapshot_date).getTime() - new Date(a.snapshot_date).getTime())[0];
            if (prevSnap) {
                total += (acc.type === 'asset' ? 1 : -1) * prevSnap.balance;
            }
        }
    });
    return { date, value: total };
});
