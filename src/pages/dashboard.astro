---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const accessToken = Astro.cookies.get("sb-access-token")?.value;
const refreshToken = Astro.cookies.get("sb-refresh-token")?.value;

if (!accessToken || !refreshToken) {
  return Astro.redirect("/signin");
}

const { data: authData, error: authError } = await supabase.auth.setSession({
  access_token: accessToken,
  refresh_token: refreshToken,
});

if (authError || !authData.user) {
  return Astro.redirect("/signin");
}

const user = authData.user;

// Month range
const now = new Date();
const firstDay = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
const lastDay = new Date(now.getFullYear(), now.getMonth() + 1, 0).toISOString().split('T')[0];

// 1. Fetch Budget Stats
const { data: categories } = await supabase
  .from('budget_categories')
  .select('*')
  .eq('user_id', user.id);

const { data: transactions } = await supabase
  .from('transactions')
  .select('*, budget_categories(name, classification)')
  .eq('user_id', user.id)
  .gte('date', firstDay)
  .lte('date', lastDay)
  .order('date', { ascending: false });

const income = (transactions || [])
  .filter(t => t.type === 'income')
  .reduce((sum, t) => sum + Number(t.amount), 0);

const spent = (transactions || [])
  .filter(t => t.type === 'expense')
  .reduce((sum, t) => sum + Number(t.amount), 0);

const budgeted = (categories || [])
  .reduce((sum, c) => sum + Number(c.monthly_limit), 0);

const remaining = budgeted - spent;

// 2. Fetch Net Worth Snapshot
const { data: accounts } = await supabase
  .from('accounts')
  .select('*, account_snapshots(balance, snapshot_date)')
  .eq('user_id', user.id);

const latestSnapshots = (accounts || []).map(acc => {
    const snap = acc.account_snapshots.sort((a: any, b: any) => new Date(b.snapshot_date).getTime() - new Date(a.snapshot_date).getTime())[0];
    return { ...acc, latestSnap: snap };
});

const totalAssets = latestSnapshots
    .filter(a => a.type === 'asset')
    .reduce((sum, a) => sum + (a.latestSnap ? Number(a.latestSnap.balance) : 0), 0);

const totalLiabilities = latestSnapshots
    .filter(a => a.type === 'liability')
    .reduce((sum, a) => sum + (a.latestSnap ? Number(a.latestSnap.balance) : 0), 0);

const netWorth = totalAssets - totalLiabilities;

// 3. To-Do / Next Actions Logic
const nextActions = [];

const uncategorizedCount = (transactions || []).filter(t => !t.category_id).length;
if (uncategorizedCount > 0) {
    nextActions.push({ label: `Review ${uncategorizedCount} new transactions`, link: '/budget', color: '#B18B53' });
}

const staleAccounts = latestSnapshots.filter(a => {
    if (!a.latestSnap) return true;
    const diff = (now.getTime() - new Date(a.latestSnap.snapshot_date).getTime()) / (1000 * 60 * 60 * 24);
    return diff > 14;
});
if (staleAccounts.length > 0) {
    nextActions.push({ label: `Update ${staleAccounts.length} old balances`, link: '/net-worth', color: '#1a1a1a' });
}

const overBudgetCats = (categories || []).filter(cat => {
    const actual = (transactions || [])
        .filter(t => t.category_id === cat.id && t.type === 'expense')
        .reduce((sum, t) => sum + Number(t.amount), 0);
    return actual > cat.monthly_limit && cat.monthly_limit > 0;
});
if (overBudgetCats.length > 0) {
    nextActions.push({ label: 'Adjust over-budget categories', link: '/budget', color: 'red' });
}

if (income === 0) {
    nextActions.push({ label: 'Log this month\'s income', link: '/budget', color: '#7ea493' });
}

// 4. Global Quick Links
const quickLinks = [
    { label: 'Budget', link: '/budget', icon: 'wallet' },
    { label: 'Net Worth', link: '/net-worth', icon: 'trending-up' },
    { label: 'Calculators', link: '/calculators', icon: 'calculator' }
];

const recentActivity = (transactions || []).slice(0, 5);
---

<Layout title="Dashboard">
  <div class="px-6 py-12 max-w-2xl mx-auto space-y-12">
    <header class="space-y-2">
      <h2 class="text-5xl font-['Cormorant_Garamond'] italic tracking-tighter">Command Center</h2>
      <p class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Hello, {user.email?.split('@')[0]}</p>
    </header>

    <!-- Main Scorecard -->
    <div class="bg-[#1a1a1a] text-white p-10 space-y-10 relative overflow-hidden">
        <div class="text-center space-y-2">
            <span class="text-[10px] font-bold uppercase tracking-[0.4em] opacity-40">Net Worth</span>
            <h3 class="text-6xl font-bold tracking-tighter">${netWorth.toLocaleString(undefined, { minimumFractionDigits: 2 })}</h3>
        </div>
        
        <div class="grid grid-cols-3 gap-4 text-center pt-8 border-t border-white/5">
            <div class="space-y-1">
                <span class="text-[8px] font-bold uppercase tracking-[0.3em] opacity-40">Income</span>
                <p class="text-lg font-bold tracking-tighter text-[#7ea493]">${income.toLocaleString(undefined, { maximumFractionDigits: 0 })}</p>
            </div>
            <div class="space-y-1 border-x border-white/5 px-2">
                <span class="text-[8px] font-bold uppercase tracking-[0.3em] opacity-40">Spent</span>
                <p class="text-lg font-bold tracking-tighter">${spent.toLocaleString(undefined, { maximumFractionDigits: 0 })}</p>
            </div>
            <div class="space-y-1">
                <span class="text-[8px] font-bold uppercase tracking-[0.3em] opacity-40">Left</span>
                <p class={["text-lg font-bold tracking-tighter", remaining < 0 ? "text-[#B18B53]" : ""].join(' ')}>{remaining < 0 ? '-' : ''}${Math.abs(remaining).toLocaleString(undefined, { maximumFractionDigits: 0 })}</p>
            </div>
        </div>
    </div>

    <!-- Next Actions -->
    {nextActions.length > 0 && (
        <section class="space-y-6">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Next Actions</h4>
            <div class="grid gap-3">
                {nextActions.map(action => (
                    <a href={action.link} class="flex justify-between items-center bg-white p-5 border border-[#1a1a1a]/5 hover:border-[#B18B53]/20 transition-all group">
                        <span class="text-[11px] font-bold uppercase tracking-widest">{action.label}</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="opacity-10 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="m9 18 6-6-6-6"/></svg>
                    </a>
                ))}
            </div>
        </section>
    )}

    <!-- Quick Access Icons -->
    <section class="grid grid-cols-3 gap-4">
        {quickLinks.map(link => (
            <a href={link.link} class="bg-white border border-[#1a1a1a]/5 p-6 text-center space-y-3 hover:border-[#B18B53]/40 transition-all">
                <div class="opacity-20 flex justify-center">
                    {link.icon === 'wallet' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H5a2 2 0 0 0 0 4h15a1 1 0 0 0 1-1v-4"/><path d="M17 12h.01"/></svg>}
                    {link.icon === 'trending-up' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>}
                    {link.icon === 'calculator' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>}
                </div>
                <span class="text-[9px] font-bold uppercase tracking-widest block">{link.label}</span>
            </a>
        ))}
    </section>

    <!-- Recent Activity -->
    <section class="space-y-6">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Recent Activity</h4>
        <div class="space-y-2">
            {recentActivity.length === 0 && <p class="text-xs opacity-40 italic py-8 border border-dashed border-[#1a1a1a]/10 text-center">No recent activity. Start by adding a transaction.</p>}
            {recentActivity.map(t => (
                <div class="flex justify-between items-center p-4 bg-white border border-[#1a1a1a]/5">
                    <div class="space-y-1">
                        <p class="text-[11px] font-bold uppercase tracking-tight">{t.merchant}</p>
                        <p class="text-[9px] opacity-30 uppercase tracking-widest">{t.budget_categories?.name || 'Uncategorized'}</p>
                    </div>
                    <p class={`text-sm font-bold tracking-tighter ${t.type === 'income' ? 'text-[#7ea493]' : ''}`}>
                        {t.type === 'income' ? '+' : ''}${Number(t.amount).toLocaleString()}
                    </p>
                </div>
            ))}
            {recentActivity.length > 0 && (
                <a href="/budget" class="block text-center text-[9px] font-bold uppercase tracking-widest opacity-30 hover:opacity-100 pt-4 underline">View all transactions</a>
            )}
        </section>

    <footer class="pt-12 text-center border-t border-[#1a1a1a]/5">
        <p class="text-[9px] font-bold uppercase tracking-[0.2em] opacity-20">Orren Command Center v1.0</p>
    </footer>
  </div>
</Layout>
