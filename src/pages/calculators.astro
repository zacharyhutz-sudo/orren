---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Calculators">
  <div class="px-6 py-12 max-w-2xl mx-auto space-y-12">
    <header class="space-y-4">
      <h2 class="text-5xl font-['Cormorant_Garamond'] italic tracking-tighter">Money Calculators</h2>
      <p class="text-[10px] font-bold uppercase tracking-[0.2em] opacity-40">Financial decision engines</p>
    </header>

    <div class="grid gap-4">
      <!-- Debt Arbitrage -->
      <a href="/calculators/debt-arbitrage" class="group bg-white border border-[#1a1a1a]/5 p-8 space-y-4 hover:border-[#B18B53]/40 transition-all">
        <div class="flex justify-between items-start">
            <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Debt Payoff vs. Investing</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-10 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <p class="text-xs opacity-60 leading-relaxed max-w-sm">Determine whether to pay off debt or invest, and generate an optimal multi-debt payoff schedule.</p>
        <div class="flex gap-2">
            <span class="text-[8px] font-bold uppercase tracking-widest bg-[#f2efeb] px-2 py-1">Payoff Order</span>
            <span class="text-[8px] font-bold uppercase tracking-widest bg-[#f2efeb] px-2 py-1">Invest vs Debt</span>
            <span class="text-[8px] font-bold uppercase tracking-widest bg-[#f2efeb] px-2 py-1">Interest Savings</span>
        </div>
      </a>

      <!-- Retirement -->
      <a href="/calculators/retirement" class="group bg-white border border-[#1a1a1a]/5 p-8 space-y-4 hover:border-[#B18B53]/40 transition-all">
        <div class="flex justify-between items-start">
            <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Retirement</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-10 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <p class="text-xs opacity-60 leading-relaxed max-w-sm">Calculate how long your money will last and what you need to save for the finish line.</p>
      </a>

      <!-- Compound Interest -->
      <a href="/calculators/compound-interest" class="group bg-white border border-[#1a1a1a]/5 p-8 space-y-4 hover:border-[#B18B53]/40 transition-all">
        <div class="flex justify-between items-start">
            <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Compound Interest</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-10 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <p class="text-xs opacity-60 leading-relaxed max-w-sm">Visualize the power of time and consistency on your investments.</p>
      </a>

      <!-- Coast FIRE -->
      <a href="/calculators/coast-fire" class="group bg-white border border-[#1a1a1a]/5 p-8 space-y-4 hover:border-[#B18B53]/40 transition-all">
        <div class="flex justify-between items-start">
            <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Coast FIRE</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-10 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <p class="text-xs opacity-60 leading-relaxed max-w-sm">Find out when you've saved enough to never have to contribute to retirement again.</p>
      </a>

      <!-- Mortgage -->
      <a href="/calculators/mortgage" class="group bg-white border border-[#1a1a1a]/5 p-8 space-y-4 hover:border-[#B18B53]/40 transition-all">
        <div class="flex justify-between items-start">
            <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Mortgage</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-10 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <p class="text-xs opacity-60 leading-relaxed max-w-sm">Break down your monthly payment, interest, and amortization schedule.</p>
      </a>

      <!-- Auto Loan -->
      <a href="/calculators/auto-loan" class="group bg-white border border-[#1a1a1a]/5 p-8 space-y-4 hover:border-[#B18B53]/40 transition-all">
        <div class="flex justify-between items-start">
            <h3 class="text-3xl font-['Cormorant_Garamond'] italic tracking-tighter">Auto Loan</h3>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-10 group-hover:opacity-100 group-hover:translate-x-1 transition-all"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <p class="text-xs opacity-60 leading-relaxed max-w-sm">Calculate payments and total cost for your next vehicle purchase.</p>
      </a>
    </div>
  </div>
</Layout>
