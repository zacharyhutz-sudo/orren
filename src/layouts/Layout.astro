---
import '../styles/global.css';

interface Props {
	title: string;
  showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Orren</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
	</head>
  <body class="noise min-h-screen bg-[#f2efeb] text-[#1a1a1a] selection:bg-[#B18B53]/20 font-['Plus_Jakarta_Sans'] antialiased overflow-x-hidden pb-20 md:pb-0">
    <!-- Header for Mobile & Desktop -->
    {showNav && (
      <header class="flex p-6 md:p-8 justify-between items-center border-b border-[#1a1a1a]/5 bg-white/40 backdrop-blur-sm sticky top-0 z-[60]">
        <h1 class="text-3xl font-['Cormorant_Garamond'] tracking-tighter"><a href="/">ORREN</a></h1>
        
        <nav class="flex items-center gap-4 md:gap-12">
          <!-- Desktop Menu -->
          <ul class="hidden md:flex gap-12 text-[10px] font-bold uppercase tracking-[0.2em]">
            <li><a href="/budget" class="opacity-40 hover:opacity-100 transition-opacity">Budget</a></li>
            <li><a href="/net-worth" class="opacity-40 hover:opacity-100 transition-opacity">Net Worth</a></li>
            <li><a href="/calculators" class="opacity-40 hover:opacity-100 transition-opacity">Calculators</a></li>
          </ul>
          
          <div class="hidden md:block h-4 w-px bg-[#1a1a1a]/10"></div>
          
          <a href="/profile" class="opacity-40 hover:opacity-100 transition-opacity flex items-center gap-2 group">
            <span class="hidden md:inline text-[10px] font-bold uppercase tracking-[0.2em]">Profile</span>
            <div class="p-2 border border-[#1a1a1a]/5 rounded-full group-hover:border-[#1a1a1a]/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
          </a>
        </nav>
      </header>
    )}

    <slot />
    
    <!-- iOS Style Bottom Navigation (Mobile Only) -->
    {showNav && (
      <nav class="fixed bottom-0 left-0 right-0 bg-white/80 backdrop-blur-xl border-t border-[#1a1a1a]/5 px-6 py-3 flex justify-around items-center z-50 md:hidden">
        <a href="/budget" class="flex flex-col items-center gap-1 opacity-40 hover:opacity-100 transition-opacity">
          <div class="p-1"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <span class="text-[10px] font-bold uppercase tracking-tighter">Budget</span>
        </a>
        <a href="/net-worth" class="flex flex-col items-center gap-1 opacity-40 hover:opacity-100 transition-opacity">
          <div class="p-1"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg></div>
          <span class="text-[10px] font-bold uppercase tracking-tighter">Worth</span>
        </a>
        <a href="/calculators" class="flex flex-col items-center gap-1 opacity-40 hover:opacity-100 transition-opacity">
          <div class="p-1"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg></div>
          <span class="text-[10px] font-bold uppercase tracking-tighter">Tools</span>
        </a>
      </nav>
    )}
  </body>
</html>
