---
import '../styles/global.css';

interface Props {
	title: string;
  showNav?: boolean;
}

const { title, showNav = true } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Budget', href: '/budget', icon: 'wallet' },
  { label: 'Worth', href: '/net-worth', icon: 'trending-up' },
  { label: 'Tools', href: '/calculators', icon: 'calculator' }
];

function isActive(href: string) {
  if (href === '/budget' && currentPath === '/budget') return true;
  if (href === '/net-worth' && currentPath === '/net-worth') return true;
  if (href === '/calculators' && currentPath.startsWith('/calculators')) return true;
  return false;
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Orren</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">
	</head>
  <body class="noise min-h-dvh bg-[#f2efeb] text-[#1a1a1a] selection:bg-[#B18B53]/20 font-['Plus_Jakarta_Sans'] antialiased overflow-x-hidden pb-[calc(5rem+env(safe-area-inset-bottom))] md:pb-0">
    <!-- Header for Mobile & Desktop -->
    {showNav && (
      <header class="flex p-6 md:p-8 justify-between items-center border-b border-[#1a1a1a]/5 bg-white/40 backdrop-blur-sm sticky top-0 z-[60]">
        <h1 class="text-3xl font-['Cormorant_Garamond'] tracking-tighter"><a href="/">ORREN</a></h1>
        
        <nav class="flex items-center gap-4 md:gap-12">
          <!-- Desktop Menu -->
          <ul class="hidden md:flex gap-12 text-[10px] font-bold uppercase tracking-[0.2em]">
            {navItems.map(item => (
              <li>
                <a href={item.href} class={`transition-opacity ${isActive(item.href) ? 'text-[#B18B53]' : 'opacity-40 hover:opacity-100'}`}>
                  {item.label === 'Worth' ? 'Net Worth' : item.label}
                </a>
              </li>
            ))}
          </ul>
          
          <div class="hidden md:block h-4 w-px bg-[#1a1a1a]/10"></div>
          
          <a href="/profile" class="opacity-40 hover:opacity-100 transition-opacity flex items-center gap-2 group">
            <span class="hidden md:inline text-[10px] font-bold uppercase tracking-[0.2em]">Profile</span>
            <div class="p-2 border border-[#1a1a1a]/5 rounded-full group-hover:border-[#1a1a1a]/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
          </a>
        </nav>
      </header>
    )}

    <slot />
    
    <!-- iOS Style Bottom Navigation (Mobile Only) -->
    {showNav && (
      <nav class="fixed inset-x-0 bottom-0 bg-white/80 backdrop-blur-xl border-t border-[#1a1a1a]/5 px-6 pb-[calc(0.75rem+env(safe-area-inset-bottom))] pt-3 flex justify-around items-center z-[90] md:hidden">
        {navItems.map(item => (
          <a href={item.href} class={`flex flex-col items-center gap-1 transition-all ${isActive(item.href) ? 'text-[#B18B53]' : 'opacity-40 hover:opacity-100'}`}>
            <div class="p-1">
              {item.icon === 'wallet' && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
              {item.icon === 'trending-up' && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>}
              {item.icon === 'calculator' && <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>}
            </div>
            <span class="text-[10px] font-bold uppercase tracking-tighter">{item.label}</span>
          </a>
        ))}
      </nav>
    )}

    <!-- Toast / Notification Container -->
    <div id="toast-container" class="fixed top-24 left-1/2 -translate-x-1/2 z-[100] w-full max-w-sm px-6 pointer-events-none"></div>

    <style is:global>
      /* Mobile-First Dialog Overrides */
      dialog {
          width: 100vw;
          height: 100dvh;
          max-width: 100vw !important;
          max-height: 100dvh !important;
          margin: 0 !important;
          padding: 0 !important;
          border: none !important;
          background: #f2efeb;
          overflow-y: auto;
          box-sizing: border-box;
      }

      dialog::backdrop {
          background: rgba(26, 26, 26, 0.4);
          backdrop-filter: blur(8px);
      }

      /* Desktop Dialog Restoration */
      @media (min-width: 768px) {
          dialog {
              width: auto;
              height: auto;
              max-width: 32rem !important;
              max-height: 90dvh !important;
              margin: auto !important;
              border: 1px solid rgba(26, 26, 26, 0.1) !important;
              background: white;
              border-radius: 0;
          }
      }

      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>

    <script is:inline>
      window.orren = {
        toast: (message, type = 'info') => {
          const container = document.getElementById('toast-container');
          const toast = document.createElement('div');
          toast.className = `bg-[#1a1a1a] text-white p-4 mb-3 shadow-2xl flex justify-between items-center animate-in fade-in slide-in-from-top-4 duration-300 pointer-events-auto border-l-4 ${type === 'error' ? 'border-red-500' : 'border-[#B18B53]'}`;
          toast.innerHTML = `
            <span class="text-[11px] font-bold uppercase tracking-widest">${message}</span>
            <button onclick="this.parentElement.remove()" class="opacity-40 hover:opacity-100 ml-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </button>
          `;
          container.appendChild(toast);
          setTimeout(() => {
            toast.classList.add('animate-out', 'fade-out', 'slide-out-to-top-4');
            setTimeout(() => toast.remove(), 300);
          }, 4000);
        },
        confirm: (message) => {
          // Simplest fallback for now that matches style
          return window.confirm(message);
        }
      };
    </script>
  </body>
</html>
